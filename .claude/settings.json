{
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(npx xlsx-cli:*)",
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(git status:*)",
      "Bash(git branch --show-current:*)",
      "Bash(git branch --list:*)",
      "Bash(git branch -v:*)",
      "Bash(git branch -a:*)",
      "Bash(git branch -d:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git stash push:*)",
      "Bash(git stash list:*)",
      "Bash(git stash pop:*)",
      "Bash(git checkout -b:*)",
      "Bash(git checkout main:*)",
      "Bash(git checkout feature/:*)",
      "Bash(git checkout fix/:*)",
      "Bash(git merge:*)",
      "Bash(git worktree:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git rev-parse:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(unzip:*)",
      "Bash(curl:*)",
      "Bash(wc:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-lint.sh"
          }
        ]
      }
    ]
  }
}
